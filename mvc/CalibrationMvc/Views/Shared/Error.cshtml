@{
    ViewData["Title"] = "Hata";
}

<div class="d-flex align-items-center justify-content-center" style="min-height: 60vh;">
    <div class="text-center">
        <div class="mb-4">
            <i class="bi bi-exclamation-triangle-fill text-danger" style="font-size: 4rem;"></i>
        </div>
        <h2 class="fw-bold text-danger">Bir Hata Oluştu</h2>
        <p class="text-muted mb-4">İşleminiz sırasında beklenmeyen bir hata oluştu. Lütfen tekrar deneyin.</p>
        @if (ViewBag.ErrorMessage != null)
        {
            <div class="alert alert-danger d-inline-block text-start" style="max-width: 500px;">
                <i class="bi bi-info-circle me-2"></i>@ViewBag.ErrorMessage
            </div>
        }
        <div class="mt-3">
            <a asp-controller="Dashboard" asp-action="Index" class="btn btn-primary me-2">
                <i class="bi bi-house me-1"></i>Anasayfaya Dön
            </a>
            <a href="javascript:history.back()" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i>Geri
            </a>
        </div>
    </div>
</div>
