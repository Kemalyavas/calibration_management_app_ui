@model List<CalibrationMvc.DTOs.ProcedureDto>
@{
    ViewData["Title"] = "Prosedürler";
    ViewData["BreadcrumbController"] = "Prosedürler";
    ViewData["BreadcrumbPage"] = "Liste";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="fw-bold mb-0"><i class="bi bi-file-text me-2"></i>Kalibrasyon Prosedürleri</h5>
    <span class="text-muted small">@Model.Count prosedür</span>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th class="px-3 py-3 small fw-semibold">Prosedür No</th>
                            <th class="py-3 small fw-semibold">Prosedür Adı</th>
                            <th class="py-3 small fw-semibold">Versiyon</th>
                            <th class="py-3 small fw-semibold">Kalibrasyon Tipi</th>
                            <th class="py-3 small fw-semibold text-end pe-3">İşlem</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var procedure in Model)
                        {
                            <tr>
                                <td class="px-3 small"><code>@procedure.ProcedureNumber</code></td>
                                <td class="small fw-semibold">@procedure.Name</td>
                                <td class="small">
                                    @if (!string.IsNullOrEmpty(procedure.Version))
                                    {
                                        <span class="badge bg-light text-dark border">v@procedure.Version</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td class="small text-muted">@(procedure.CalibrationTypeName ?? "-")</td>
                                <td class="text-end pe-3">
                                    <a asp-action="Details" asp-route-id="@procedure.Id"
                                       class="btn btn-outline-primary btn-sm">
                                        <i class="bi bi-eye me-1"></i>Detay
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="bi bi-file-text text-muted" style="font-size: 3rem; opacity: 0.4;"></i>
                <p class="text-muted mt-3">Prosedür bulunmuyor.</p>
            </div>
        }
    </div>
</div>
