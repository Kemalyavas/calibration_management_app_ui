@model DeviceListViewModel
@{
    ViewData["Title"] = "Cihaz Listesi";
    ViewData["BreadcrumbController"] = "Cihazlar";
    ViewData["BreadcrumbPage"] = "Liste";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="fw-bold mb-0"><i class="bi bi-cpu me-2"></i>Cihaz Listesi</h5>
    <div class="d-flex gap-2">
        <a asp-action="ExportExcel" asp-route-departmentId="@Model.SelectedDepartmentId"
           asp-route-machineId="@Model.SelectedMachineId"
           asp-route-deviceType="@Model.SelectedDeviceType"
           asp-route-search="@Model.SearchTerm"
           class="btn btn-outline-success btn-sm">
            <i class="bi bi-file-earmark-excel me-1"></i>Excel'e Aktar
        </a>
        @if (User.IsInRole("Operator") || User.IsInRole("Manager"))
        {
            <a asp-action="Create" class="btn btn-primary btn-sm">
                <i class="bi bi-plus me-1"></i>Yeni Cihaz
            </a>
        }
    </div>
</div>

<!-- Filtre -->
<div class="card border-0 shadow-sm mb-3">
    <div class="card-body py-3">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-3">
                <label class="form-label small fw-semibold mb-1">Departman</label>
                <select name="departmentId" id="filterDepartment" class="form-select form-select-sm">
                    <option value="">Tüm Departmanlar</option>
                    @foreach (var dept in Model.Departments)
                    {
                        <option value="@dept.Id" selected="@(Model.SelectedDepartmentId == dept.Id)">@dept.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-semibold mb-1">Makine</label>
                <select name="machineId" id="filterMachine" class="form-select form-select-sm">
                    <option value="">Tüm Makineler</option>
                    @foreach (var machine in Model.Machines)
                    {
                        <option value="@machine.Id" selected="@(Model.SelectedMachineId == machine.Id)">@machine.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-semibold mb-1">Cihaz Tipi</label>
                <select name="deviceType" class="form-select form-select-sm">
                    <option value="">Tümü</option>
                    <option value="test" selected="@(Model.SelectedDeviceType == "test")">Test</option>
                    <option value="reference" selected="@(Model.SelectedDeviceType == "reference")">Referans</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-semibold mb-1">Arama</label>
                <input type="text" name="search" class="form-control form-control-sm" value="@Model.SearchTerm" placeholder="Kod, ad..." />
            </div>
            <div class="col-md-2 d-flex gap-1">
                <button type="submit" class="btn btn-primary btn-sm flex-grow-1">
                    <i class="bi bi-search me-1"></i>Filtrele
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-x"></i>
                </a>
            </div>
        </form>
    </div>
</div>

<!-- Tablo -->
<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        @if (Model.Devices.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th class="px-3 py-3 small fw-semibold">Makine</th>
                            <th class="py-3 small fw-semibold">Cihaz Kodu</th>
                            <th class="py-3 small fw-semibold">Cihaz Adı</th>
                            <th class="py-3 small fw-semibold">Tip</th>
                            <th class="py-3 small fw-semibold">Kalan Gün</th>
                            <th class="py-3 small fw-semibold text-end pe-3">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var device in Model.Devices)
                        {
                            var days = device.DaysRemaining;
                                string badgeClass;
                                string daysText;
                                if (days == null)
                                {
                                    badgeClass = "badge-days-secondary";
                                    daysText = "Belirsiz";
                                }
                                else if (days < 0)
                                {
                                    badgeClass = "badge-days-danger";
                                    daysText = $"{Math.Abs(days.Value)} gün geçti";
                                }
                                else if (days < 7)
                                {
                                    badgeClass = "badge-days-danger";
                                    daysText = $"{days} gün";
                                }
                                else if (days <= 15)
                                {
                                    badgeClass = "badge-days-warning";
                                    daysText = $"{days} gün";
                                }
                                else
                                {
                                    badgeClass = "badge-days-success";
                                    daysText = $"{days} gün";
                                }
                            <tr>
                                <td class="px-3 small">@(device.MachineName ?? "-")</td>
                                <td class="small"><code>@device.DeviceCode</code></td>
                                <td class="small fw-semibold">@device.DeviceName</td>
                                <td>
                                    <span class="badge @(device.DeviceType == "reference" ? "bg-info text-dark" : "bg-secondary") badge-sm">
                                        @(device.DeviceType == "reference" ? "Referans" : "Test")
                                    </span>
                                </td>
                                <td>
                                    <span class="badge @badgeClass px-2 py-1">@daysText</span>
                                </td>
                                <td class="text-end pe-3">
                                    <div class="d-flex justify-content-end gap-1">
                                        <a asp-action="Details" asp-route-id="@device.Id"
                                           class="btn btn-outline-secondary btn-sm" title="Detay">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        @if (User.IsInRole("Operator") || User.IsInRole("Manager"))
                                        {
                                            <a asp-action="Edit" asp-route-id="@device.Id"
                                               class="btn btn-outline-primary btn-sm" title="Güncelle">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            @if (device.DeviceType != "reference")
                                            {
                                                <a asp-controller="Calibrations" asp-action="Create" asp-route-deviceId="@device.Id"
                                                   class="btn btn-outline-success btn-sm" title="Kalibrasyon">
                                                    <i class="bi bi-clipboard-check"></i>
                                                </a>
                                            }
                                        }
                                        @if (!string.IsNullOrEmpty(device.ProcedureNumber))
                                        {
                                            <a asp-controller="Procedures" asp-action="Index" asp-route-number="@device.ProcedureNumber"
                                               class="btn btn-outline-info btn-sm" title="Prosedür">
                                                <i class="bi bi-file-text"></i>
                                            </a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Sayfalama -->
            @if (Model.TotalPages > 1)
            {
                <div class="d-flex justify-content-between align-items-center px-3 py-2 border-top">
                    <small class="text-muted">
                        Toplam @Model.TotalCount kayıt | Sayfa @Model.CurrentPage / @Model.TotalPages
                    </small>
                    <div class="d-flex gap-1">
                        @if (Model.CurrentPage > 1)
                        {
                            <a asp-action="Index"
                               asp-route-page="@(Model.CurrentPage - 1)"
                               asp-route-departmentId="@Model.SelectedDepartmentId"
                               asp-route-machineId="@Model.SelectedMachineId"
                               asp-route-deviceType="@Model.SelectedDeviceType"
                               asp-route-search="@Model.SearchTerm"
                               class="btn btn-outline-secondary btn-sm">
                                <i class="bi bi-chevron-left"></i> Önceki
                            </a>
                        }
                        @if (Model.CurrentPage < Model.TotalPages)
                        {
                            <a asp-action="Index"
                               asp-route-page="@(Model.CurrentPage + 1)"
                               asp-route-departmentId="@Model.SelectedDepartmentId"
                               asp-route-machineId="@Model.SelectedMachineId"
                               asp-route-deviceType="@Model.SelectedDeviceType"
                               asp-route-search="@Model.SearchTerm"
                               class="btn btn-outline-secondary btn-sm">
                                Sonraki <i class="bi bi-chevron-right"></i>
                            </a>
                        }
                    </div>
                </div>
            }
        }
        else
        {
            <div class="text-center py-5">
                <i class="bi bi-cpu text-muted" style="font-size: 3rem; opacity: 0.4;"></i>
                <p class="text-muted mt-3">Gösterilecek cihaz bulunamadı.</p>
                @if (User.IsInRole("Operator") || User.IsInRole("Manager"))
                {
                    <a asp-action="Create" class="btn btn-primary btn-sm">
                        <i class="bi bi-plus me-1"></i>İlk Cihazı Ekle
                    </a>
                }
            </div>
        }
    </div>
</div>
