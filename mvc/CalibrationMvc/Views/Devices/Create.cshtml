@model DeviceFormViewModel
@{
    ViewData["Title"] = "Yeni Cihaz Ekle";
    ViewData["BreadcrumbController"] = "Cihazlar";
    ViewData["BreadcrumbPage"] = "Yeni Cihaz";
    var device = Model.Device ?? new CalibrationMvc.DTOs.CreateDeviceDto();
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="fw-bold mb-0"><i class="bi bi-plus-circle me-2"></i>Yeni Cihaz Ekle</h5>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Listeye Dön
    </a>
</div>

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()

    <div class="row g-3">
        <!-- Sol kolon -->
        <div class="col-md-6">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-bottom py-2">
                    <h6 class="mb-0 fw-semibold small text-muted text-uppercase">Cihaz Bilgileri</h6>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Cihaz No <span class="text-danger">*</span></label>
                        <input name="DeviceCode" value="@device.DeviceCode" class="form-control" required placeholder="örn: CAL-001" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Cihaz Adı <span class="text-danger">*</span></label>
                        <input name="DeviceName" value="@device.DeviceName" class="form-control" required placeholder="Cihaz adını girin" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Marka</label>
                        <input name="Brand" value="@device.Brand" class="form-control" placeholder="Marka" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Model</label>
                        <input name="Model" value="@device.Model" class="form-control" placeholder="Model" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Üretici</label>
                        <input name="Manufacturer" value="@device.Manufacturer" class="form-control" placeholder="Üretici firma" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Birim</label>
                        <input name="Unit" value="@device.Unit" class="form-control" placeholder="örn: mm, bar, °C" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Kullanım Yeri</label>
                        <input name="LocationOfUse" value="@device.LocationOfUse" class="form-control" placeholder="Kullanım yeri" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Departman</label>
                        <select id="departmentId" class="form-select">
                            <option value="">Departman Seçiniz</option>
                            @foreach (var dept in Model.Departments)
                            {
                                <option value="@dept.Id">@dept.Name</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Makine</label>
                        <select name="MachineId" id="machineId" class="form-select">
                            <option value="">Önce departman seçin</option>
                            @foreach (var machine in Model.Machines)
                            {
                                <option value="@machine.Id" selected="@(device.MachineId == machine.Id)">@machine.Name</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Prosedür No</label>
                        <input name="ProcedureNumber" value="@device.ProcedureNumber" class="form-control" placeholder="örn: P-001" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Kalibre Eden</label>
                        <input name="CalibratedBy" value="@device.CalibratedBy" class="form-control" placeholder="Kalibre eden kişi/kurum" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Ölçüm Hassasiyeti</label>
                        <input name="MeasurementAccuracy" value="@device.MeasurementAccuracy" class="form-control" placeholder="örn: ±0.001 mm" />
                    </div>
                </div>
            </div>
        </div>

        <!-- Sağ kolon -->
        <div class="col-md-6">
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-header bg-white border-bottom py-2">
                    <h6 class="mb-0 fw-semibold small text-muted text-uppercase">Kalibrasyon Bilgileri</h6>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Referans Kodu</label>
                        <input name="ReferenceCode" value="@device.ReferenceCode" class="form-control" placeholder="Referans kodu" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Kalibrasyon Frekansı</label>
                        <input name="CalibrationFrequency" value="@device.CalibrationFrequency" class="form-control" placeholder="örn: 12 ay, 6 ay" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Kalibrasyon Tarihi</label>
                        <input type="date" name="CalibrationDate"
                               value="@(device.CalibrationDate?.ToString("yyyy-MM-dd"))"
                               class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Sonraki Kalibrasyon Tarihi</label>
                        <input type="date" name="NextCalibrationDate"
                               value="@(device.NextCalibrationDate?.ToString("yyyy-MM-dd"))"
                               class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Cihaz Tipi <span class="text-danger">*</span></label>
                        <select name="DeviceType" id="deviceType" class="form-select">
                            <option value="test" selected="@(device.DeviceType != "reference")">Test</option>
                            <option value="reference" selected="@(device.DeviceType == "reference")">Referans</option>
                        </select>
                    </div>
                    <div class="row">
                        <div class="col-6 mb-3">
                            <label class="form-label small fw-semibold">Min Aralık</label>
                            <input type="number" step="any" name="MinRange" value="@device.MinRange" class="form-control" placeholder="0" />
                        </div>
                        <div class="col-6 mb-3">
                            <label class="form-label small fw-semibold">Max Aralık</label>
                            <input type="number" step="any" name="MaxRange" value="@device.MaxRange" class="form-control" placeholder="100" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Teknik Tolerans</label>
                        <input name="TechnicalTolerance" value="@device.TechnicalTolerance" class="form-control" placeholder="örn: ±0.05" />
                    </div>
                </div>
            </div>

            <!-- Doğrulama Değerleri -->
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-bottom py-2 d-flex justify-content-between align-items-center">
                    <h6 class="mb-0 fw-semibold small text-muted text-uppercase">Doğrulama Değerleri</h6>
                    <button type="button" id="addVerificationRow" class="btn btn-outline-primary btn-sm">
                        <i class="bi bi-plus me-1"></i>Değer Ekle
                    </button>
                </div>
                <div class="card-body">
                    <div class="row mb-2">
                        <div class="col-md-3"><small class="fw-semibold text-muted">Doğrulama</small></div>
                        <div class="col-md-3"><small class="fw-semibold text-muted">Tolerans</small></div>
                        <div class="col-md-3"><small class="fw-semibold text-muted">Belirsizlik</small></div>
                        <div class="col-md-3"></div>
                    </div>
                    <div id="verificationRows">
                        @{
                            int rowCount = Math.Max(device.VerificationValues.Length, 3);
                        }
                        @for (int i = 0; i < rowCount; i++)
                        {
                            <div class="verification-row row mb-2 align-items-center">
                                <div class="col-md-3">
                                    <input type="number" step="any" name="VerificationValues[@i]"
                                           value="@(i < device.VerificationValues.Length ? device.VerificationValues[i]?.ToString() : "")"
                                           class="form-control form-control-sm" placeholder="Değer" />
                                </div>
                                <div class="col-md-3">
                                    <input type="number" step="any" name="ToleranceValues[@i]"
                                           value="@(i < device.ToleranceValues.Length ? device.ToleranceValues[i]?.ToString() : "")"
                                           class="form-control form-control-sm tolerance-field" placeholder="Tol." />
                                </div>
                                <div class="col-md-3">
                                    <input type="number" step="any" name="UncertaintyValues[@i]"
                                           value="@(i < device.UncertaintyValues.Length ? device.UncertaintyValues[i]?.ToString() : "")"
                                           class="form-control form-control-sm uncertainty-field" placeholder="Bel." />
                                </div>
                                <div class="col-md-3">
                                    @if (i > 0)
                                    {
                                        <button type="button" class="btn btn-outline-danger btn-sm remove-row">
                                            <i class="bi bi-x"></i>
                                        </button>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-3 d-flex justify-content-end gap-2">
        <a asp-action="Index" class="btn btn-outline-secondary">İptal</a>
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-check2 me-1"></i>Kaydet
        </button>
    </div>
</form>

@section Scripts {
    <script src="~/js/device-form.js"></script>
}
