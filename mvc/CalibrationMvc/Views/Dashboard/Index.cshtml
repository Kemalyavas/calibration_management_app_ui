@{
    ViewData["Title"] = "Anasayfa";
}

<div class="mb-4">
    <h4 class="fw-bold mb-1">Hoş Geldiniz, @ViewBag.FullName</h4>
    <p class="text-muted mb-0">Prometeon Kalibrasyon Yönetim Sistemi</p>
</div>

<div class="row g-3">
    <!-- Cihaz Listesi — Herkes -->
    <div class="col-sm-6 col-lg-4">
        <a asp-controller="Devices" asp-action="Index" class="text-decoration-none">
            <div class="card dashboard-card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3 p-4">
                    <div class="rounded-3 p-3" style="background: #dbeafe;">
                        <i class="bi bi-cpu fs-2" style="color: #1d4ed8;"></i>
                    </div>
                    <div>
                        <h6 class="fw-bold mb-1 text-dark">Cihaz Listesi</h6>
                        <small class="text-muted">Tüm kalibrasyon cihazları</small>
                    </div>
                </div>
            </div>
        </a>
    </div>

    <!-- Prosedürler — Herkes -->
    <div class="col-sm-6 col-lg-4">
        <a asp-controller="Procedures" asp-action="Index" class="text-decoration-none">
            <div class="card dashboard-card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3 p-4">
                    <div class="rounded-3 p-3" style="background: #dcfce7;">
                        <i class="bi bi-file-text fs-2" style="color: #15803d;"></i>
                    </div>
                    <div>
                        <h6 class="fw-bold mb-1 text-dark">Prosedürler</h6>
                        <small class="text-muted">Kalibrasyon prosedürleri</small>
                    </div>
                </div>
            </div>
        </a>
    </div>

    @if (User.IsInRole("Operator") || User.IsInRole("Manager"))
    {
        <!-- Cihaz Ekle -->
        <div class="col-sm-6 col-lg-4">
            <a asp-controller="Devices" asp-action="Create" class="text-decoration-none">
                <div class="card dashboard-card border-0 shadow-sm h-100">
                    <div class="card-body d-flex align-items-center gap-3 p-4">
                        <div class="rounded-3 p-3" style="background: #fef9c3;">
                            <i class="bi bi-plus-circle fs-2" style="color: #a16207;"></i>
                        </div>
                        <div>
                            <h6 class="fw-bold mb-1 text-dark">Cihaz Ekle</h6>
                            <small class="text-muted">Yeni cihaz kaydı oluştur</small>
                        </div>
                    </div>
                </div>
            </a>
        </div>

        <!-- Kalibrasyon Girişi -->
        <div class="col-sm-6 col-lg-4">
            <a asp-controller="Calibrations" asp-action="Create" class="text-decoration-none">
                <div class="card dashboard-card border-0 shadow-sm h-100">
                    <div class="card-body d-flex align-items-center gap-3 p-4">
                        <div class="rounded-3 p-3" style="background: #ede9fe;">
                            <i class="bi bi-clipboard-check fs-2" style="color: #6d28d9;"></i>
                        </div>
                        <div>
                            <h6 class="fw-bold mb-1 text-dark">Kalibrasyon Girişi</h6>
                            <small class="text-muted">Yeni kalibrasyon kaydı</small>
                        </div>
                    </div>
                </div>
            </a>
        </div>
    }

    @if (User.IsInRole("Manager"))
    {
        <!-- Onay Bekleyenler -->
        <div class="col-sm-6 col-lg-4">
            <a asp-controller="Approvals" asp-action="Index" class="text-decoration-none">
                <div class="card dashboard-card border-0 shadow-sm h-100">
                    <div class="card-body d-flex align-items-center gap-3 p-4">
                        <div class="rounded-3 p-3" style="background: #fee2e2;">
                            <i class="bi bi-check2-square fs-2" style="color: #b91c1c;"></i>
                        </div>
                        <div>
                            <h6 class="fw-bold mb-1 text-dark">Onay Bekleyenler</h6>
                            <small class="text-muted">Bekleyen onay istekleri</small>
                            @if (ViewBag.PendingCount != null && (int)ViewBag.PendingCount > 0)
                            {
                                <span class="badge bg-danger ms-1">@ViewBag.PendingCount</span>
                            }
                        </div>
                    </div>
                </div>
            </a>
        </div>
    }
</div>

<!-- Özet istatistikleri -->
@if (ViewBag.Stats != null)
{
    <div class="row g-3 mt-2">
        <div class="col-12">
            <h6 class="fw-bold text-muted text-uppercase mb-3" style="font-size: 0.75rem; letter-spacing: 0.08em;">Özet</h6>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body text-center py-3">
                    <div class="fs-3 fw-bold text-primary">@ViewBag.Stats.TotalDevices</div>
                    <div class="text-muted small">Toplam Cihaz</div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body text-center py-3">
                    <div class="fs-3 fw-bold text-danger">@ViewBag.Stats.OverdueDevices</div>
                    <div class="text-muted small">Vadesi Geçmiş</div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body text-center py-3">
                    <div class="fs-3 fw-bold text-warning">@ViewBag.Stats.DueSoonDevices</div>
                    <div class="text-muted small">Yakında Dolacak</div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body text-center py-3">
                    <div class="fs-3 fw-bold text-success">@ViewBag.Stats.CalibrationsDone</div>
                    <div class="text-muted small">Bu Ay Yapılan</div>
                </div>
            </div>
        </div>
    </div>
}
